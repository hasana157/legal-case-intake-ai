# =============================================================================
# .env.example — Opposing-Argument Simulator
# Copy this file to api/.env and fill in your actual keys.
# DO NOT commit the real .env to version control (it is in .gitignore).
# =============================================================================

# ── Groq LLM (case extraction & argument generation) ─────────────────────────
# Get your free API key at: https://console.groq.com/keys
# Used by: api/services/case_parser.py, api/services/llm_service.py
GROQ_API_KEY=gsk_your_groq_key_here

# ── Qdrant Vector Database (RAG grounding) ────────────────────────────────────
# Populated by: python api/scripts/ingest_caselaw.py
#
# Step 1: Create free cluster at https://cloud.qdrant.io/
# Step 2: Paste your cluster URL and API key below
# Step 3: Run python api/scripts/ingest_caselaw.py (~30-45 min locally)
#
QDRANT_URL=https://your-cluster.us-east-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Frontend API Base URL ─────────────────────────────────────────────────────
# Used by the Next.js frontend to reach the FastAPI backend.
# Local development: leave as http://localhost:8000
# Production (Vercel): set to your Vercel deployment URL in Vercel dashboard
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Copy this file:
#      cp .env.example api/.env
#
# 2. Fill in GROQ_API_KEY from https://console.groq.com/keys
#
# 3. Set up Qdrant (required for RAG):
#      a. Create free cluster at https://cloud.qdrant.io/
#      b. Fill in QDRANT_URL and QDRANT_API_KEY
#      c. Run: python api/scripts/ingest_caselaw.py
#
# 4. Start the backend:
#      cd api && uvicorn main:app --reload --port 8000
#
# 5. Start the frontend (in a separate terminal):
#      cd frontend && npm run dev
#
# 6. Open http://localhost:3000
#
# =============================================================================
