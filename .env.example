# Groq API Configuration
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here


# RAG System Configuration (Prevents Hallucinations)
# Knowledge base location (local ChromaDB - created by setup_knowledge_base.py)
RAG_DB_PATH=./legal_db

# Embedding model (sentence-transformers, CPU-friendly, no GPU required)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG Search parameters
RAG_SEARCH_K=5              # Number of legal documents to retrieve
RAG_RELEVANCE_THRESHOLD=0.4 # Minimum relevance score (0-1)

# Optional: Streamlit configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# Debug mode
DEBUG=false

# SETUP INSTRUCTIONS:
# 1. Create virtual environment: python3 -m venv venv
# 2. Activate: source venv/bin/activate (or venv\Scripts\activate on Windows)
# 3. Install dependencies: pip install -r requirements.txt
# 4. Initialize RAG knowledge base: python setup_knowledge_base.py
# 5. Update GROQ_API_KEY above with your actual key
# 6. Run the app: streamlit run app_rag.py
