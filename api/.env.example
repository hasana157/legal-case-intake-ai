# =============================================================================
# api/.env.example
# Rename this file to api/.env and fill in your actual keys.
# DO NOT commit the real .env to version control.
# =============================================================================

# ── Groq LLM (Milestone 2+) ──────────────────────────────────────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# ── Qdrant Vector Database (Milestone 3+) ────────────────────────────────────
# Populated by: notebooks/caselaw_ingestion.ipynb  (run in Google Colab)
# Setup guide:  notebooks/README.md
#
# Step 1: Create free cluster at https://cloud.qdrant.io/
# Step 2: Run notebooks/caselaw_ingestion.ipynb (~60 min)
# Step 3: Paste your credentials below
#
QDRANT_URL=https://your-cluster.us-east-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
