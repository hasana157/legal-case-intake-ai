# =============================================================================
# api/.env.example
# Rename this file to .env and fill in your actual keys.
# DO NOT commit the real .env to version control.
# =============================================================================

# ── Extraction (Milestone 2) ─────────────────────────────────────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY="your_groq_api_key_here"

# ── Retrieval (Milestone 3) ──────────────────────────────────────────────────
# Get your free Cluster URL and API Key at https://cloud.qdrant.io
QDRANT_URL="https://your-cluster.us-east-1-0.aws.cloud.qdrant.io"
QDRANT_API_KEY="your_qdrant_api_key_here"
